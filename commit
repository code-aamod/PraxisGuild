# To make changes in other than main #

# Clone the repository via HTTPS or SSH
git clone https://github.com/code-aamod/PraxisGuild.git

# Enter the repository folder
cd PraxisGuild

# Configure your Git identity on the new machine so your commits are correctly attributed to you:
git config --global user.name "Your Name"
git config --global user.email "your-email@example.com"

# Have a look at README.md

# After you make changes
git add .
git add <file_name>

